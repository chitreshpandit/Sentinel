{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowGetConfiguredSecret",
            "Effect": "Allow",
            "Action": "secretsmanager:GetSecretValue",
            "Resource": "arn:aws:secretsmanager:<YOUR_REGION>:<YOUR_ACCOUNT_ID>:secret:<YOUR_SECRET_NAME>-*"
        }
    ]
}